            {
              "id": "shoulder-car",
              "name": "Shoulder CARs",
              "reps": "5 slow reps each direction",
              "notes": "Post-pressing shoulder maintenance"
            }
          ]
        }
      },
      "rationale": {
        "session_why": {
          "text": "Strict press develops vertical push strength under full CNS availability. EMOM format maintains session flow and auto-regulates rest. The metcon uses EMOM format with built-in rest to manage glycolytic fatigue across a 16-minute time domain, mixing monostructural cardio with pressing volume.",
          "source": "Haff & Triplett - NSCA Essentials 4th ed",
          "url_or_ref": "Chapter 17-18"
        },
        "movement_why": {
          "text": "Strict press is the foundation for all vertical pressing per CrossFit's strength skill development. Push press in the metcon reinforces the pressing pattern under fatigue. Row provides monostructural cardio per weekly balance requirements, and burpees add full-body conditioning.",
          "source": "Glassman 2002 - CrossFit Journal",
          "url_or_ref": "What is Fitness?"
        },
        "loading_why": {
          "text": "E2MOM format at 75% 1RM for 3 reps per round provides adequate recovery (120 seconds) while maintaining engagement. This is appropriate for Week 1-2 baseline building with moderate intensity. The interval ensures phosphocreatine recovery without excessive downtime, training pacing discipline.",
          "source": "Bompa & Haff - Periodization 5th ed",
          "url_or_ref": "Chapter 9"
        }
      }
    },
