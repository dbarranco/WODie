          "duration_minutes": 7,
          "movements": [
            {
              "id": "thoracic-rotation",
              "name": "Thoracic Rotation",
              "reps": "10 each side",
              "notes": "Reduce thoracic stiffness from pressing"
            },
            {
              "id": "pigeon-pose",
              "name": "Pigeon Pose",
              "reps": "60 seconds each side",
              "notes": "Hip mobility maintenance"
