      "category": [
        "strength"
      ],
      "equipment": [
        "barbell",
        "plates",
        "box",
        "jump rope"
      ],
      "duration_minutes": 60,
      "blocks": {
        "static_warmup": {
          "duration_minutes": 5,
          "movements": [
            {
              "id": "cat-cow",
              "name": "Cat-Cow",
              "reps": "10 reps",
              "notes": "Spinal mobility prep"
            },
            {
              "id": "world-greatest-stretch",
              "name": "World's Greatest Stretch",
              "reps": "5 each side",
              "notes": "Hip and thoracic mobility"
            },
            {
              "id": "glute-bridge",
              "name": "Glute Bridge",
              "reps": "15 reps",
              "notes": "Glute activation, posterior chain prep"
            }
          ]
        },
        "active_warmup": {
          "duration_minutes": 5,
          "movements": [
            {
              "id": "good-morning",
              "name": "Good Morning",
              "reps": "10 reps",
              "equipment": "empty barbell",
              "notes": "Hinge pattern activation"
            },
            {
              "id": "romanian-deadlift",
              "name": "Romanian Deadlift",
              "reps": "8 reps",
              "load": "empty barbell",
              "notes": "Hamstring loading prep, deadlift movement prep"
            },
            {
              "id": "box-jump",
              "name": "Box Jump",
              "reps": "5 reps",
              "load": "low height",
              "notes": "Power output prep, hip extension activation"
            }
          ]
