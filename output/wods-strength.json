        "strength": {
          "duration_minutes": 24,
          "label": "Deadlift \u2014 Wave Loading",
          "movements": [
            {
              "id": "deadlift",
              "name": "Deadlift",
              "sets": 6,
              "reps": "3-3-3-3-3-3",
              "load": "75%-80%-85%-75%-82%-87% 1RM",
              "load_fallback_rpe": "RPE 7-8-9-7-8-9",
              "rest": "180-240 seconds between sets",
              "notes": "Wave loading: oscillate between heavier and lighter loads to exploit post-activation potentiation. First wave: 75-80-85%. Second wave: 77-82-87%. Heavy sets prime the nervous system for subsequent performance.",
              "progression_scheme": "wave_loading"
            }
          ]
        },
        "metcon": {
          "duration_minutes": 14,
          "format": "AMRAP",
          "time_cap_minutes": 12,
          "rounds_or_duration": "12 minutes",
          "movements": [
            {
              "id": "box-jump",
              "name": "Box Jump",
              "reps": 10,
              "load": "24/20 inch box",
              "scaling": "Step-up or reduce height"
            },
            {
              "id": "kb-swing",
              "name": "Kettlebell Swing (Russian)",
              "reps": 15,
              "load": "53/35 lbs",
              "scaling": "Reduce weight"
            },
            {
              "id": "double-under",
              "name": "Double-Under",
              "reps": 30,
              "scaling": "90 single-unders"
            }
          ],
          "target_score": "7\u20139 rounds",
          "timer_config": {
            "type": "AMRAP",
            "duration_seconds": 720,
            "interval_seconds": null
          }
        },
        "cooldown": {
          "duration_minutes": 7,
          "movements": [
            {
              "id": "pigeon-pose",
              "name": "Pigeon Pose",
              "reps": "90 seconds each side",
              "notes": "Hip external rotation stretch"
            },
            {
              "id": "foam-roll-lats",
              "name": "Foam Roll \u2014 Lats",
              "reps": "60 seconds each side",
              "notes": "Upper back tension release from deadlifting"
            },
            {
              "id": "hip-flexor-stretch",
              "name": "Hip Flexor Stretch",
              "reps": "60 seconds each side",
              "notes": "Hip flexor lengthening post-hinge work"
            }
          ]
        }
      },
      "rationale": {
        "session_why": {
          "text": "Deadlift targets the hinge pattern and posterior chain strength. The metcon follows with power-based movements (box jumps) that exploit residual neural activation from heavy deadlifts, paired with glycolytic conditioning. AMRAP format at 12 minutes targets the glycolytic-aerobic transition zone without excessive fatigue.",
          "source": "Gastin 2001 - Energy System Interaction",
          "url_or_ref": "Sports Medicine 31(10)"
        },
        "movement_why": {
          "text": "Deadlift develops maximal strength in the hinge pattern. Box jumps paired post-deadlift utilize post-activation potentiation principles. KB swings reinforce the hinge pattern under fatigue, and double-unders add monostructural cardio per weekly balance requirements.",
          "source": "Robbins 2005 - Post-Activation Potentiation",
          "url_or_ref": "Journal of Strength and Conditioning Research 19(2)"
        },
        "loading_why": {
          "text": "Wave loading exploits PAP by oscillating between heavy and moderate loads. First wave (75-80-85%) primes the nervous system; second wave (77-82-87%) allows higher performance at similar percentages due to neural priming. This is appropriate for Week 2 strength emphasis with experienced athletes.",
          "source": "Zatsiorsky & Kraemer - Science and Practice of Strength Training",
          "url_or_ref": "Chapter 3"
        }
      }
    },
