    {
      "id": "wod-str-001",
      "title": "Back Squat Foundation + Glycolytic Push",
      "category": [
        "strength"
      ],
      "equipment": [
        "barbell",
        "plates",
        "rack",
        "pull-up bar"
      ],
      "duration_minutes": 60,
      "blocks": {
        "static_warmup": {
          "duration_minutes": 5,
          "movements": [
            {
              "id": "hip-circle",
              "name": "Hip Circles",
              "reps": "10 each direction",
              "notes": "Open hip capsule, increase synovial fluid"
            },
            {
              "id": "world-greatest-stretch",
              "name": "World's Greatest Stretch",
              "reps": "5 each side",
              "notes": "Hip flexor, thoracic rotation, hamstring mobility"
            },
            {
              "id": "cat-cow",
              "name": "Cat-Cow",
              "reps": "10 reps",
              "notes": "Spinal segmentation and warmup"
            }
          ]
        },
        "active_warmup": {
          "duration_minutes": 5,
          "movements": [
            {
              "id": "air-squat",
              "name": "Air Squat",
              "reps": "15 reps",
              "notes": "Movement-specific warmup for squat pattern"
            },
            {
              "id": "good-morning",
              "name": "Good Morning",
              "reps": "10 reps",
              "equipment": "empty barbell",
              "notes": "Posterior chain activation, hinge pattern prep"
            },
            {
              "id": "inchworm",
              "name": "Inchworm",
              "reps": "8 reps",
              "notes": "Hamstring lengthening, shoulder stabilization"
            }
          ]
        },
        "strength": {
          "duration_minutes": 22,
          "label": "Back Squat \u2014 Baseline Volume",
          "movements": [
            {
              "id": "back-squat",
              "name": "Back Squat",
              "sets": 5,
              "reps": 5,
              "load": "70% 1RM",
              "load_fallback_rpe": "RPE 7",
              "rest": "180 seconds between sets",
              "notes": "Straight sets. Focus on depth and bar path. Week 1 baseline loading.",
              "progression_scheme": "straight_sets"
            }
          ]
        },
        "metcon": {
          "duration_minutes": 15,
          "format": "For Time",
          "time_cap_minutes": 12,
          "rounds_or_duration": "5 Rounds For Time",
          "movements": [
            {
              "id": "push-up",
              "name": "Push-Up",
              "reps": 15,
              "scaling": "Knee push-up or banded push-up"
            },
            {
              "id": "pull-up",
              "name": "Pull-Up",
              "reps": 10,
              "scaling": "Banded pull-up or ring row"
            },
            {
              "id": "air-squat",
              "name": "Air Squat",
              "reps": 20,
              "scaling": "Reduce reps to 15"
            }
          ],
          "target_score": "Complete all 5 rounds in 8\u201312 minutes",
          "timer_config": {
            "type": "For Time",
            "duration_seconds": 720,
            "interval_seconds": null
          }
        },
        "cooldown": {
          "duration_minutes": 8,
          "movements": [
            {
              "id": "pigeon-pose",
              "name": "Pigeon Pose",
              "reps": "90 seconds each side",
              "notes": "Hip external rotation, glute stretch"
            },
            {
              "id": "foam-roll-quads",
              "name": "Foam Roll \u2014 Quads",
              "reps": "60 seconds each leg",
              "notes": "Reduce post-squat muscle tension"
            },
            {
              "id": "hip-flexor-stretch",
              "name": "Hip Flexor Stretch",
              "reps": "60 seconds each side",
              "notes": "Address anterior hip tightness from squatting"
            }
          ]
        }
      },
      "rationale": {
        "session_why": {
          "text": "Back squat is placed first to exploit full CNS availability for heavy loading. The metcon follows with bodyweight movements only to avoid posterior chain interference while targeting the glycolytic system through 8\u201312 minute time domain. This session structure prevents concurrent training interference by separating strength stimulus from conditioning load.",
          "source": "Wilson et al 2012 - Concurrent Training Meta-Analysis",
          "url_or_ref": "Journal of Strength and Conditioning Research 26(8)"
        },
        "movement_why": {
          "text": "Back squat develops foundational lower body strength and is a fundamental squat pattern per CrossFit's 10 physical skills (Strength). The metcon uses push-ups and pull-ups to balance horizontal and vertical push/pull patterns while air squats provide lower body endurance without excessive loading that would compromise recovery.",
          "source": "Glassman 2002 - CrossFit Journal",
          "url_or_ref": "What is Fitness?"
        },
        "loading_why": {
          "text": "Week 1 baseline loading at 70% 1RM for 5x5 establishes technique and moderate volume per linear periodization principles. Straight sets allow consistent execution quality and work capacity development at this intensity. Rest periods of 180 seconds ensure phosphocreatine recovery between sets for strength adaptation.",
          "source": "Bompa & Haff - Periodization 5th ed",
          "url_or_ref": "Chapter 9"
        }
      }
    },
    {
      "id": "wod-str-002",
