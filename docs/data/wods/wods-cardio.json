          "time_cap_minutes": 18,
          "rounds_or_duration": "3 Rounds",
          "movements": [
            {
              "name": "Run",
              "reps_or_duration": "800m",
              "load": "bodyweight",
              "notes": "Moderate-hard pace, sustainable across rounds"
            },
            {
              "name": "Air Squat",
              "reps_or_duration": "30 reps",
              "load": "bodyweight",
              "notes": "Consistent tempo, maintain quality"
            },
            {
              "name": "Burpee",
              "reps_or_duration": "15 reps",
